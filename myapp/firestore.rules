rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Wardrobe items — egna plagg: full access. Andras: läs (för The Market)
    match /wardrobeItems/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Outfit planer — bara ägaren
    match /outfitPlans/{docId} {
      allow read: if request.auth != null &&
        (resource == null || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Sparade kollage / outfits — alla inloggade kan läsa (för SellerModal), bara ägaren skriver
    match /savedCollages/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Användarprofiler — egna: full access. Andras: läs
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Likes — alla inloggade kan läsa (för att räkna likes), bara ägaren skapar/tar bort
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Follows — alla inloggade kan läsa, bara följaren kan skriva/ta bort
    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }
  }
}
